# Never commit real data or outputs by default
data/raw/**
data/intermediate/**
data/derived/**
output/tables/**
output/figures/**
output/logs/**

# Keep directory placeholders
!data/raw/.gitkeep
!data/intermediate/.gitkeep
!data/derived/.gitkeep
!output/tables/.gitkeep
!output/figures/.gitkeep
!output/logs/.gitkeep
